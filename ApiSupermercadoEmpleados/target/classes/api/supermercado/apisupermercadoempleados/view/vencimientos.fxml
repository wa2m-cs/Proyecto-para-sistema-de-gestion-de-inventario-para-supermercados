<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="api.supermercado.apisupermercadoempleados.controller.VencimientosController"
      spacing="10" style="-fx-padding:16;" prefWidth="1100" prefHeight="700">

    <HBox spacing="10">
        <Button fx:id="btnVolver" text="← Volver" onAction="#volver"/>
        <Label text="Vencimientos" style="-fx-font-size:18; -fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <DatePicker fx:id="dpAntesDe"/>
        <Button text="Buscar" onAction="#loadVencimientos"/>
    </HBox>

    <TableView fx:id="tblVencimientos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colProducto" text="Producto" prefWidth="520"/>
            <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="120"/>
            <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="180"/>
            <TableColumn fx:id="colFecha" text="Vence" prefWidth="140"/>
        </columns>
    </TableView>

</VBox>